# 🐹 Language Specific (编程语言相关)
# ------------------------------------------------------------------------------

# Go
go.work
go.work.sum
coverage.txt
cover.out

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
env/
ENV/

# Node.js / Frontend
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ------------------------------------------------------------------------------
# 🔑 Environment & Secrets (项目环境与敏感信息)
# ------------------------------------------------------------------------------

.env*
!.env.example
!docker/matrix/.env
*.pem
*.key
cert.log

# Server config may contain sensitive settings (api_key, etc.)
/configs/server.yaml


# ------------------------------------------------------------------------------
# 🤖 Agent & Assistant States (AI 助手与工具状态)
# ------------------------------------------------------------------------------

# Claude / Serena / HotPlex Agents
.claude/*
!.claude/skills
!.claude/rules
!.claude/workflows

.agent/*
!.agent/rules
!.agent/skills/
!.agent/workflows/

# .serena is used for workspace state (project.yml is usually tracked, others ignored)
# We keep current behavior but make it cleaner
.serena/cache/
.serena/memories/


# ------------------------------------------------------------------------------
# 📝 Documentation & Project Specific (文档与项目特定)
# ------------------------------------------------------------------------------

# Documentation Site (Generated / Search Index)
.loki/
/.logs/
/logs/

# Worktrees
.worktrees/

# Generated Assets
docs/images/png/

# Release Process
RELEASE_NOTES.md
release_notes_*.txt


# ------------------------------------------------------------------------------
# 🧹 Temporary Files & Logs (临时文件与日志)
# ------------------------------------------------------------------------------

*.log
*.bak
*.tmp
*.temp
main
!cmd/hotplexd/main.go


