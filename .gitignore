*.ipr

# Other editors
*.swp
*.swo
*~


# ------------------------------------------------------------------------------
# 🏗 Binaries & Build Artifacts (二进制文件与构建产物)
# ------------------------------------------------------------------------------

# Output Directories
dist/
bin/
out/

# Go Binaries
# Fix: Using /hotplexd to target root binary without ignoring cmd/hotplexd/ folder
/hotplexd
/cmd/hotplexd/hotplexd

# Generic Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out


