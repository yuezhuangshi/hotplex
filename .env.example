# ==============================================================================
# HotPlex 环境配置模版
# ==============================================================================
# 使用说明：
# 1. 复制此文件为 '.env'：cp .env.example .env
# 2. 根据你的实际凭据更新下方变量。
# 3. 出于安全考虑，切勿将你的 '.env' 文件提交到版本控制系统。
#
# 配置分层规则：
# - .env 文件：全局参数、Bot 标识、敏感凭据、持久化配置
# - configs/chatapps/*.yaml：平台行为配置（mode, permission, system_prompt 等）
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 核心服务器 (Core Server)
# ------------------------------------------------------------------------------

# 服务端口（默认：8080）
HOTPLEX_PORT=8080

# 日志级别：DEBUG, INFO, WARN, ERROR（默认：INFO）
HOTPLEX_LOG_LEVEL=INFO

# 日志格式：json, text（默认：json）
HOTPLEX_LOG_FORMAT=text

# API 安全令牌（生产环境必选）
# 生成建议：openssl rand -hex 32
HOTPLEX_API_KEY=在此处生成强令牌

# 多 API Key 支持（逗号分隔，可选）
# HOTPLEX_API_KEYS=key1,key2,key3

# ------------------------------------------------------------------------------
# 2. 引擎配置 (Engine)
# ------------------------------------------------------------------------------

# 执行超时（默认：30m）
HOTPLEX_EXECUTION_TIMEOUT=30m

# 空闲超时（默认：1h）
HOTPLEX_IDLE_TIMEOUT=1h

# ------------------------------------------------------------------------------
# 3. Provider 配置
# ------------------------------------------------------------------------------

# Provider 类型：claude-code, opencode（默认：claude-code）
HOTPLEX_PROVIDER_TYPE=claude-code

# Provider 模型（默认：sonnet）
HOTPLEX_PROVIDER_MODEL=sonnet

# Provider 二进制路径（可选）
# HOTPLEX_PROVIDER_BINARY=/usr/local/bin/claude

# OpenCode 兼容层（默认：true）
HOTPLEX_OPENCODE_COMPAT_ENABLED=true

# GitHub PAT（用于 Git 操作）
GITHUB_TOKEN=ghp_在此处填写你的GitHub令牌

# ------------------------------------------------------------------------------
# 4. 项目目录 (Projects) - Docker 部署用
# ------------------------------------------------------------------------------

# 项目工作目录（Bot 特定，用于隔离不同 Bot 的工作空间）
HOTPLEX_PROJECTS_DIR=${HOME}/.slack/BOT_UXXXXXXXXXX

# Git 配置文件路径（Bot 特定，用于隔离不同 Bot 的 Git 身份）
HOTPLEX_GITCONFIG=${HOME}/.gitconfig-hotplex

# ------------------------------------------------------------------------------
# 5. 原生大脑 (Native Brain) - 可选
# ------------------------------------------------------------------------------

# Brain API 密钥（设置后自动启用）
# HOTPLEX_BRAIN_API_KEY=

# Brain Provider（默认：openai）
# HOTPLEX_BRAIN_PROVIDER=openai

# Brain 模型（默认：gpt-4o-mini）
# HOTPLEX_BRAIN_MODEL=gpt-4o-mini

# Brain 端点（可选，用于自定义端点）
# HOTPLEX_BRAIN_ENDPOINT=

# Brain 超时秒数（默认：10）
# HOTPLEX_BRAIN_TIMEOUT_S=10

# Brain 缓存大小（默认：1000）
# HOTPLEX_BRAIN_CACHE_SIZE=1000

# Brain 重试配置
# HOTPLEX_BRAIN_MAX_RETRIES=3
# HOTPLEX_BRAIN_RETRY_MIN_WAIT_MS=100
# HOTPLEX_BRAIN_RETRY_MAX_WAIT_MS=5000

# ------------------------------------------------------------------------------
# 6. 消息存储 (Message Store) - 持久化配置
# ------------------------------------------------------------------------------

# 启用消息存储（默认：true）
HOTPLEX_MESSAGE_STORE_ENABLED=true

# 存储类型：sqlite, postgres, memory（默认：sqlite）
HOTPLEX_MESSAGE_STORE_TYPE=sqlite

# SQLite 配置
HOTPLEX_MESSAGE_STORE_SQLITE_PATH=~/.hotplex/chatapp_messages.db
HOTPLEX_MESSAGE_STORE_SQLITE_MAX_SIZE_MB=1024

# 流式存储配置
HOTPLEX_MESSAGE_STORE_STREAMING_ENABLED=true
HOTPLEX_MESSAGE_STORE_STREAMING_TIMEOUT=5m

# ------------------------------------------------------------------------------
# 7. Slack Bot 配置
# ------------------------------------------------------------------------------
# 申请地址：https://api.slack.com/apps

# Bot 标识（用于 mention 检测和 session 隔离）
HOTPLEX_SLACK_BOT_USER_ID=UXXXXXXXXXX

# BOT Token（敏感）
HOTPLEX_SLACK_BOT_TOKEN=xoxb-在此填入

# ------------------------------------------------------------------------------
# ⚠️ [ACTION REQUIRED]
# 你的 Slack 用户 ID（例如：U12345678）。
# 获取方式：个人资料 -> 更多 (...) -> 复制会员 ID。
# 此变量用于安全策略，定义谁是该 Bot 的主要所有者。
HOTPLEX_SLACK_PRIMARY_OWNER=UXXXXXXXXXX

# App Token（Socket Mode 必需，敏感）
HOTPLEX_SLACK_APP_TOKEN=xapp-在此填入

# Signing Secret（HTTP Mode 必需，敏感）
HOTPLEX_SLACK_SIGNING_SECRET=

# ------------------------------------------------------------------------------
# 8. 飞书 (Feishu) 配置
# ------------------------------------------------------------------------------

# HOTPLEX_FEISHU_APP_ID=
# HOTPLEX_FEISHU_APP_SECRET=
# HOTPLEX_FEISHU_VERIFICATION_TOKEN=
# HOTPLEX_FEISHU_ENCRYPT_KEY=

# ------------------------------------------------------------------------------
# 9. CORS 配置
# ------------------------------------------------------------------------------

# 允许的源（逗号分隔）
# HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------------------------
# 10. Git 身份配置 (容器内代码提交用)
# ------------------------------------------------------------------------------
# 设置后容器启动时自动注入 git config --global，无需依赖宿主机 .gitconfig
GIT_USER_NAME="HotPlex Core"
GIT_USER_EMAIL=core@hotplex.dev

# ------------------------------------------------------------------------------
# 12. 镜像与构建模式 (Orchestration Mode)
# ------------------------------------------------------------------------------
#
# 💡 如果需要手动覆盖默认代理，可以取消下方注释：
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
#
# A. 极速模式 (直接使用远程预构建镜像，默认)
COMPOSE_FILE=docker-compose.yml
# HOTPLEX_IMAGE=ghcr.io/hrygo/hotplex:latest
#
# B. 本地构建模式 (基于源码开发)
# COMPOSE_FILE=docker-compose.yml:docker-compose.build.yml
# HOTPLEX_IMAGE=hotplex:dev
#
# ─────────────────────────────────────────────────────────────────
# Docker 构建参数 (仅本地构建模式需要)
# ─────────────────────────────────────────────────────────────────
HOST_UID=1000
# VERSION=dev
# COMMIT=unknown
# BUILD_TIME=unknown

# ==============================================================================
# 平台行为配置请修改 YAML 文件：
# - configs/chatapps/slack.yaml    - Slack 行为配置
# - configs/chatapps/feishu.yaml   - Feishu 行为配置
# ==============================================================================
