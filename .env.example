# HotPlex Environment Configuration
# Copy this file to .env and configure as needed

# ===========================================
# Server Configuration
# ===========================================

# Server port (default: 8080)
PORT=8080

# Session idle timeout (default: 30m)
# Examples: 10m, 1h, 2h30m
IDLE_TIMEOUT=30m

# ===========================================
# Security Configuration
# ===========================================

# CORS: Allowed origins for WebSocket connections (comma-separated)
# Required for browser-based clients
# Default: localhost only (development mode)
#
# Examples:
#   Single origin: HOTPLEX_ALLOWED_ORIGINS=https://your-frontend.com
#   Multiple: HOTPLEX_ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-frontend.com
#   Development: HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# API Key Authentication (optional but recommended for production)
# When configured, all WebSocket connections must include a valid API key
# API key can be provided via:
#   - HTTP Header: X-API-Key: your-secret-key
#   - Query Parameter: ?api_key=your-secret-key
#
# Single API key:
HOTPLEX_API_KEY=your-secret-key-here

# Or multiple API keys (comma-separated, takes precedence over HOTPLEX_API_KEY):
# HOTPLEX_API_KEYS=key1,key2,key3

# ===========================================
# Logging Configuration
# ===========================================

# Log level: DEBUG, INFO, WARN, ERROR (default: DEBUG)
# LOG_LEVEL=INFO

# ===========================================
# Development vs Production Examples
# ===========================================

# --- Development (.env.development) ---
# PORT=8080
# IDLE_TIMEOUT=30m
# HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# # No API key required for development

# --- Production (.env.production) ---
# PORT=8080
# IDLE_TIMEOUT=1h
# HOTPLEX_ALLOWED_ORIGINS=https://your-frontend.com
# HOTPLEX_API_KEY=use-a-strong-random-key-here
